#T#PoiConstellationFunctions
    #ifdef POI_CONSTELLATION
        float PoiDistLine(float2 p, float2 a, float2 b)
        {
            float2 pa = p-a;
            float2 ba = b-a;
            float t = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
            return length(pa - ba * t);
        }

        float PoiLine(float2 p, float2 a, float2 b)
        {
            float2 pa = p-a;
            float2 ba = b-a;
            float t = clamp(dot(pa, ba) / dot(ba, ba), 0.0, 1.0);
            float d = length(pa - ba * t);
            float lineLength = length(a-b);
            float baseThickness = lerp(0.005, 0.05, _ConstellationLineThickness);
            float centerThinness = 4.0 * t * (1.0 - t);
            float minThickness = lerp(baseThickness, baseThickness * 0.3, _ConstellationLineThicknessVariation);
            float thickness = lerp(minThickness, baseThickness, 1.0 - centerThinness);
            
            float lineFade = 1.0 - smoothstep(0.0, thickness, d);
            float lengthFade = smoothstep(1.2, 0.05, lineLength);
            
            return lineFade * lengthFade;
        }

        float PoiN21(float2 p)
        {
            p = frac(p*float2(233.213, 853.23));
            p += dot(p, p+23.24);
            return frac(p.x*p.y);
        }

        float2 PoiN22(float2 p)
        {
            float n = PoiN21(p);
            return float2(n, PoiN21(p+n));
        }

        float2 PoiGetPos(float2 id, float2 off, float time)
        {
            float2 n = PoiN22(id + off) * time;
            return off + sin(n) * _ConstellationStarMovement;
        }

        float PoiLayer(float2 uv, float time)
        {
            float2 gv = frac(uv) - 0.5;
            float2 id = floor(uv);
            float lines = 0.0;
            float sparkles = 0.0;

            float2 p[9];
            int i = 0;
            
            for(float y=-1.0;y<=1.0;y++){
                for(float x=-1.0;x<=1.0;x++){
                    p[i++] = PoiGetPos(id, float2(x, y), time);
                }
            }
            
            float t = time * _ConstellationTwinkleSpeed;
            
            for(int j = 0; j < 9; j++)
            {
                lines += PoiLine(gv, p[4], p[j]);
                
                float2 vec = (p[j] - gv) * 30.0 * (1-_ConstellationStarSize*0.75);
                float sparkle = 1.0/max(dot(vec, vec), 0.01);
                sparkle = min(sparkle, 5.0);
                
                sparkles += sparkle*(sin(t+frac(p[j].x)*10.0)*0.5 + 0.5);
            }
            
            lines += PoiLine(gv, p[1], p[3]);
            lines += PoiLine(gv, p[1], p[5]);
            lines += PoiLine(gv, p[3], p[7]);
            lines += PoiLine(gv, p[5], p[7]);
            
            lines = min(lines * _ConstellationLineBrightness, 1.0);
            sparkles = min(sparkles * _ConstellationStarBrightness / 4.0, 1.0);
            
            return min(lines + sparkles, 1.0);
        }

        void applyConstellation(inout PoiFragData poiFragData, in PoiMesh poiMesh, in PoiMods poiMods)
        {
            if(_ConstellationEnable == 0) return;

            float4 constellationColorFinal = _ConstellationColor;
            if(_ConstellationColorThemeIndex > 0)
            {
                constellationColorFinal.rgb = poiThemeColor(poiMods, _ConstellationColor.rgb, _ConstellationColorThemeIndex);
            }

            float mask = 1.0;
            #if defined(PROP_CONSTELLATIONMASK) || !defined(OPTIMIZER_ENABLED)
                mask = POI2D_SAMPLER_PAN(_ConstellationMask, _MainTex, poiUV(poiMesh.uv[_ConstellationMaskUV], _ConstellationMask_ST), _ConstellationMaskPan).r;
            #endif
            if(_ConstellationMaskInvert) 
            {
                mask = 1.0 - mask;
            }
            
            if(_ConstellationMaskGlobalMask > 0)
            {
                mask = maskBlend(mask, poiMods.globalMask[_ConstellationMaskGlobalMask - 1], _ConstellationMaskGlobalMaskBlendType);
            }
            
            if(mask == 0.0) 
            {
                return;
            }

            float2 uv = poiMesh.uv[_ConstellationUV].xy - _ConstellationCenter;
            uv *= _ConstellationDensity;
            
            float m = 0.0;

            float t = _Time.y * _ConstellationPanSpeed.z / _ConstellationDensity + _ConstellationOffset.z;
            
            uv += (_ConstellationPanSpeed.xy / _ConstellationDensity) * _Time.y + _ConstellationOffset.xy;
            
            for(float i=0.0;i<1.0;i+= 1.0/4.0)
            {
                float z = frac(i+t);
                float size = lerp(10.0, 0.5, z);
                float fadeStart = _ConstellationDepthFade;
                float fadeEnd = 1.0 - (1.0 - _ConstellationDepthFade) * 0.2;
                fadeEnd = min(fadeEnd, 0.999);
                float fade = smoothstep(0.0, fadeStart, z) * smoothstep(1.0, fadeEnd, z);
                
                m += PoiLayer(uv * size + i*24.0, _Time.y) * fade;
            }
            
            m = min(m, 1.0);
            m *= mask;
            float constellationMask = m;
            float3 constellationColor = m * constellationColorFinal.rgb;
            
            if(_ConstellationBlendMode == 0)
            {
                poiFragData.baseColor = lerp(poiFragData.baseColor, constellationColor, constellationMask);
            }
            else if(_ConstellationBlendMode == 1)
            {
                poiFragData.baseColor = lerp(poiFragData.baseColor, poiFragData.baseColor * constellationColor, constellationMask);
            }
            else
            {
                poiFragData.baseColor += constellationColor * constellationMask;
            }
            
            poiFragData.emission += constellationColor * constellationMask * _ConstellationEmissionStrength;
            
            if(_ConstellationApplyGlobalMaskIndex > 0)
            {
                applyToGlobalMask(poiMods, _ConstellationApplyGlobalMaskIndex - 1, _ConstellationApplyGlobalMaskBlendType, constellationMask);
            }
        }
    #endif


#T#PoiConstellationFunctionCall
//ifex _ConstellationEnable==0
    #ifdef POI_CONSTELLATION
        applyConstellation(poiFragData, poiMesh, poiMods);
    #endif
